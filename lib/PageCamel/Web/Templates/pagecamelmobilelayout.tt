<!DOCTYPE HTML>
<html>
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <link REL="stylesheet" TYPE="text/css" href="/static/jquery_mobile/jquery.mobile-1.4.5.min.css[% URLReloadPostfix %]"></link>
        <link REL="stylesheet" TYPE="text/css" href="/layout/pagecamel_webgui_mobile.css[% URLReloadPostfix %]"></link>

        [% FOREACH HeadExtraCS IN HeadExtraCSS %]
            <link rel="stylesheet" href="[% HeadExtraCS %][% URLReloadPostfix %]"  type="text/css">
        [% END %]
        [% FOREACH HeadExtraCS IN HeadExtraCSSNoPostfix %]
            <link rel="stylesheet" href="[% HeadExtraCS %]"  type="text/css">
        [% END %]

        <title>[% tr.trquote(PageTitle) %] &#64; [% ProjectNameTitleTag %]</title>

        <!-- favicon stuff, generated by http://realfavicongenerator.net/ -->
        <link rel="apple-touch-icon" sizes="180x180" href="/pics/favicons/apple-touch-icon.png[% URLReloadPostfix %]">
        <link rel="icon" type="image/png" sizes="32x32" href="/pics/favicons/favicon-32x32.png[% URLReloadPostfix %]">
        <link rel="icon" type="image/png" sizes="16x16" href="/pics/favicons/favicon-16x16.png[% URLReloadPostfix %]">
        <link rel="manifest" href="/pics/favicons/manifest.json[% URLReloadPostfix %]">
        <link rel="mask-icon" href="/pics/favicons/safari-pinned-tab.svg[% URLReloadPostfix %]" color="#5bbad5">
        <link rel="shortcut icon" href="/pics/favicons/favicon.ico[% URLReloadPostfix %]">
        <meta name="apple-mobile-web-app-title" content="[% favicon_app_name %]">
        <meta name="application-name" content="[% favicon_app_name %]">
        <meta name="msapplication-config" content="/pics/favicons/browserconfig.xml[% URLReloadPostfix %]">
        <meta name="theme-color" content="#ffffff">
        <!-- end of favicon stuff -->

        <script type="text/javascript" src="/static/jquery.compiled-min.js[% URLReloadPostfix %]"></script>
        <script type="text/javascript" src="/static/jquery_mobile/jquery.mobile-1.4.5.min.js[% URLReloadPostfix %]"></script>
        <!--<script type="text/javascript" src="/static/jquery/js/jquery.cavacnote_mobile.js[% URLReloadPostfix %]"></script>-->

        [% FOREACH HeadExtraScript IN HeadExtraScripts %]
            <script type="text/javascript" src="[% HeadExtraScript %][% URLReloadPostfix %]"></script>
        [% END %]
        [% FOREACH HeadExtraScript IN HeadExtraScriptsNoPostfix %]
            <script type="text/javascript" src="[% HeadExtraScript %]"></script>
        [% END %]

        <script type="text/javascript">
            var logoutDialog;
            var ttvars = new Object;
            ttvars['trquote'] = new Object;

            $(document).ready(function(){
                // Load tt vars from master template
                loadTTVars('#mastertemplatedataset');
                loadTTVars('#masktemplatedataset');
                loadTTVars('#submasktemplatedataset');
                loadTTVars('#websocketmasktemplatedataset');
                loadTTVars('#autodialogstemplatedataset');

                $('#mobiledesktopselect_desktop').on('click', function() {
                    document.cookie = "clientMode=desktop; path=/;";
                    window.location.reload();
                    console.log("Bound the desktop link");
                });

                //_init_pagecamel_pageviewstats();

                // register all "pagecamelnavdestination onclick events
                $('[pagecamelnavdestination]').each(function() {
                    var mndest = $(this).attr('pagecamelnavdestination');
                    $(this).on('click', function() {
                        location.href=mndest;
                    });
                });

                $("select[searchable!='1']").selectmenu({
                    width: 400
                });
                $("select[searchable='1']").each(function() {
                    $(this).width(400);
                    $(this).select2();
                });

                $("input[type=checkbox]").checkify({
                    image_checked:'/pics/checkbox_classic_ON.png',
                    image_unchecked:'/pics/checkbox_classic_OFF.png',
                    image_checked_delete:'/pics/checkbox_classic_DELETE.png'
                });

                $("input[displaytype=dateandtime]").datetimepicker({
                    format: 'Y-m-d H:i:s',
                    mask:true,
                });

                $("input[displaytype=dateonly]").datepicker({
                    dateFormat: 'yy-mm-dd',
                    showOn: 'button',
                    buttonImage: '/pics/calendar.gif',
                    buttonImageOnly: true,
                    buttonText: ttvars.trquote.Calendarbutton
                });

                $("input[displaytype=timeonly]").timepicker({
                    timeFormat: 'HH:mm',
                    interval: 30,
                    minTime: '00:00',
                    maxTime: '23:30',
                    startTime: '10:00',
                    dynamic: false,
                    dropdown: true,
                    scrollbar: true
                });

                $("button, input:submit, input:reset, input:button").button();

                $("span.cavacnote").cavacnote_mobile();

                if(window.extraOnLoadBeforeTables) {
                    extraOnLoadBeforeTables();
                }

                $('#MainDataTable').statictable();

                $( "#menutabs, #submenutabs" ).buttonset();


                // AutoDialogs
                if(window.JSinitTTDialogs) {
                    JSinitTTDialogs();
                }

                $('#jsddm_top > li').bind('mouseover', jsddm_open);
                $('#jsddm_top > li').bind('mouseout',  jsddm_timer);
                $('#jsddm_side > li').bind('mouseover', jsddm_open);
                $('#jsddm_side > li').bind('mouseout',  jsddm_timer);

                // If appropriate, start the computer map
                if(window.startMap) {
                    startMap();
                }

                if(window.extraOnLoad) {
                    extraOnLoad();
                }

                $( "#tabs" ).tabs();

                if(ttvars.webappshoweyes == "1") {
                    $('.iris').xeyes();

                    function blinkeyeClose() {
                        $('.eye').css('background-color', '#000000');
                        window.setTimeout(blinkeyeOpen, 150);
                    }
                    function blinkeyeOpen() {
                        $('.eye').css('background-color', '#FFFFFF');
                        window.setTimeout(blinkeyeClose, 14000);
                    }
                    window.setTimeout(blinkeyeClose, 10000);
                }

                if(window.lateExtraOnLoad) {
                    lateExtraOnLoad();
                }

                if(ttvars.pagetitle != "Login" && ttvars.pagetitle != "Logout" && ttvars.pagetitle != "Reset Password" && ttvars.ispublicurl != "1") {
                    startSessionRefresh('lastsessionrefresh', '/user/sessionrefresh');
                }


                if(ttvars.setdocumenthref != "") {
                    document.location.href = ttvars.setdocumenthref;
                }

                if(ttvars.focusonfield != "") {
                    $(ttvars.focusonfield).focus();
                }

            });

        </script>

        [% IF ExtraHEADElements %]
            [% ExtraHEADElements %]
        [% END %]

        [% IF AdsHeaderCode != '' %]<!-- For Adblock remove code below -->
        [% AdsHeaderCode %]
        <!-- For Adblock remove code above -->[% END %]

    </head>
    <body>
        <!-- master template TT vars dataset -->
        <span id="mastertemplatedataset"
            data-urlreloadpostfix="[% URLReloadPostfix %]"
            data-webappshoweyes="[% WebAppShowEyes %]"
            data-pagetitle="[% PageTitle %]"
            data-ispublicpage="[% IsPublicPage %]"
            data-setdocumenthref="[% SetDocumentHREF %]"
            data-focusonfield="[% FocusOnField %]"
            data-trquote-all="[% tr.trquote("All") %]"
            data-trquote-countperpage="[% tr.trquote("Display _MENU_ records per page") %]"
            data-trquote-nomatches="[% tr.trquote("No matches found") %]"
            data-trquote-recordcount="[% tr.trquote("Showing _START_ to _END_ of _TOTAL_ records") %]"
            data-trquote-norecords="[% tr.trquote("Showing 0 to 0 of 0 records") %]"
            data-trquote-maxrecords="[% tr.trquote("(filtered from _MAX_ total records)") %]"
            data-trquote-first="[% tr.trquote("First") %]"
            data-trquote-last="[% tr.trquote("Last") %]"
            data-trquote-filteresults="[% tr.trquote("Filter results") %]"
            data-trquote-logout="[% tr.trquote("Logout") %]"
            data-trquote-cancel="[% tr.trquote("Cancel") %]"
            data-trquote-close="[% tr.trquote("Close") %]"
            data-trquote-calendarbutton="[% tr.trquote("Select Date") %]"
        ></span>


        [% IF header_info %]
            <div class="webgui_headerinfo">[% header_info %]</div>
        [% END %]

        [% IF header_message %]
            <div class="webgui_headermessage">
                <div class="webgui_headermessage_left"><img src="/pics/hackman2.gif"></div>
                <div class="webgui_headermessage_middle">[% header_message %]</div>
                <div class="webgui_headermessage_right"><img src="/pics/hackman2.gif"></div>
            </div>
        [% END %]

        <div class="webgui_projectbar">

            <div class="webgui_projectname">[% ProjectName %]</div>
            <div class="webgui_projectmottotext">[% ProjectMotto %]</div>
        </div>

        <div class="pagecamelmobiledesktopselectorbox">
            <div class="pagecamelmobiledesktopselectorboxtext">
                [% tr.trquote('You are viewing the (limited) mobile version of this site.') %]
                <a href="" id="mobiledesktopselect_desktop">[% tr.trquote("Click here to select the desktop version.") %]</a>
            </div>
        </div>


    <div id="pagecamelPageContent" class="pagecamelPageContent" width="100%" align="center" valign="top" border="0">
        XX_BODY_XX
        <br/>


            [% IF PageTitle != "Login" && PageTitle != "Logout" && PageTitle != "Reset Password" && PageTitle != "Register new account" %]
                <p>
                    <div>Sessionrefresh: <div id="lastsessionrefresh">[% CurrentTime %]</div></div>
                </p>
            [% END %]
    </div>

        <p align="center">
            [% IF PrivacyPolicyURL != '' %]
                <a href="[% PrivacyPolicyURL %]" target="_blank">[% tr.trquote("Privacy Policy") %]</a><br/>
            [% END %]
            [% IF ImpressumURL != '' %]
                <a href="[% ImpressumURL %]" target="_blank">[% tr.trquote("Contact/Impressum") %]</a><br/>
            [% END %]

        </p>

    [% IF PAGECAMELPAGEFOOTERTEXT != "" %]
        <div id="pagecamelpagefooter" class="pagecamelpagefooter_[% PAGECAMELPAGEFOOTERCOLOR %]">[% PAGECAMELPAGEFOOTERTEXT %]</div>
    [% END%]


    </body>
</html>
