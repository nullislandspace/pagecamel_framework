add(options){this.numpads.push(options);var keyvalues=[[{text:"[% tr.tr('+/-') %]"},{text:"[% tr.tr('ZWS') %]"},{text:"[% tr.tr('×') %]",keyCode:[106]}],[{text:"[% tr.tr('7') %]",keyCode:[103,55]},{text:"[% tr.tr('8') %]",keyCode:[104,56]},{text:"[% tr.tr('9') %]",keyCode:[57,105]}],[{text:"[% tr.tr('4') %]",keyCode:[100,52]},{text:"[% tr.tr('5') %]",keyCode:[101,53]},{text:"[% tr.tr('6') %]",keyCode:[102,54]}],[{text:"[% tr.tr('1') %]",keyCode:[97,49]},{text:"[% tr.tr('2') %]",keyCode:[98,50]},{text:"[% tr.tr('3') %]",keyCode:[99,51]}],[{text:"[% tr.tr(',') %]",keyCode:[108,188]},{text:"[% tr.tr('0') %]",keyCode:[96,48]},{text:"[% tr.tr('⌫') %]",keyCode:[8]}]];if(!options.show_keys.x){keyvalues[0][2]=null;}
if(!options.show_keys.ZWS){keyvalues[0][1]=null;}
if(!options.show_keys.pm){keyvalues[0][0]=null;}
var button_height=options.height/keyvalues.length-options.gap;if(!options.show_keys.x&&!options.show_keys.ZWS&&!options.show_keys.pm){button_height=options.height/(keyvalues.length-1)-options.gap;}
var button_width=options.width/keyvalues[0].length-options.gap;for(var buttons_y=0;buttons_y<keyvalues.length;buttons_y++){var position_y=options.y+(button_height+options.gap)*buttons_y;if(!options.show_keys.x&&!options.show_keys.ZWS&&!options.show_keys.pm){position_y=options.y+(button_height+options.gap)*(buttons_y-1);}
