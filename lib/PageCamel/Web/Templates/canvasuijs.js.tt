this.button.clear();this.arrowbutton.clear()}}class UINumpad{constructor(canvas){this.button=new UIButton();this.numpads=[];}
add(options){this.numpads.push(options);var keyvalues=[[{text:'+/-'},{text:'ZWS'},{text:'⌫',keyCode:[8]}],[{text:'7',keyCode:[103,55]},{text:'8',keyCode:[104,56]},{text:'9',keyCode:[57,105]}],[{text:'4',keyCode:[100,52]},{text:'5',keyCode:[101,53]},{text:'6',keyCode:[102,54]}],[{text:'1',keyCode:[97,49]},{text:'2',keyCode:[98,50]},{text:'3',keyCode:[99,51]}],[{text:'x',keyCode:[106]},{text:'0',keyCode:[96,48]},{text:',',keyCode:[108,188]}]];if(!options.show_keys.x){keyvalues[4][0]=null;}
if(!options.show_keys.ZWS){keyvalues[0][1]=null;}
var button_height=options.height/keyvalues.length-options.gap;var button_width=options.width/keyvalues[0].length-options.gap;for(var buttons_y=0;buttons_y<keyvalues.length;buttons_y++){var position_y=options.y+(button_height+options.gap)*buttons_y;for(var buttons_x=0;buttons_x<keyvalues[0].length;buttons_x++){if(keyvalues[buttons_y][buttons_x]!=null){var position_x=options.x+(button_width+options.gap)*buttons_x;var keyCode=undefined;if(options.allow_keyboard){keyCode=keyvalues[buttons_y][buttons_x].keyCode;}
var button={displaytext:keyvalues[buttons_y][buttons_x].text,accept_keycode:keyCode,x:position_x,y:position_y,width:button_width,height:button_height,type:'Button',callbackData:{key:options.callbackData.key,value:keyvalues[buttons_y][buttons_x].text}};this.button.add(Object.assign({},options,button));}}}
return options;}
render(ctx){this.button.render(ctx);}
onClick(x,y){this.button.onClick(x,y);}
