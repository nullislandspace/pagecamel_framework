else{ctx.font=text.font_size+'px Everson Mono';}
ctx.strokeStyle=text.border;ctx.lineWidth=text.border_width;if(text.background!==undefined){ctx.fillStyle=text.background[0];}
else{ctx.fillStyle=text.background;}
ctx.save();ctx.translate(text.center_x,text.center_y);ctx.rotate(text.angle*Math.PI/180);ctx.translate(-text.center_x,-text.center_y);if(text.displaytext){var text_width=ctx.measureText(text.displaytext).width;if(text.width!==undefined&&text.height!==undefined){if(text_width>text.width){ctx.fillText(text.displaytext,text.x,text.y+(text.height/2)+text.height/3.3,text.width);if(text.border_width!=0&&text.border_width!=undefined){ctx.strokeText(text.displaytext,text.x,text.y+(text.height/2)+text.height/3.3,text.width);}}
else{ctx.fillText(text.displaytext,text.x+(text.width-text_width)/2,text.y+(text.height/2)+text.height/3.3);if(text.border_width!=0&&text.border_width!=undefined){ctx.strokeText(text.displaytext,text.x+(text.width-text_width)/2,text.y+(text.height/2)+text.height/3.3);}}}else{ctx.fillText(text.displaytext,text.x,text.y+text.font_size/3.3);if(text.border_width!=0&&text.border_width!=undefined){ctx.strokeText(text.displaytext,text.x,text.y+text.font_size/3.3);}}}
ctx.restore();}}}
onClick(x,y){return;}
