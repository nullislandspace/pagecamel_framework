<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />

        [% IF BaseHREFUrl != "" %]<base href="[% BaseHREFUrl %]">[% END %]

        [%IF EnableRemoteConsoleLog == "1" %]
            <script type="text/javascript" src="/static/remoteconsolelog.js[% URLReloadPostfix %]"></script>
        [% END %]

        <link REL="stylesheet" TYPE="text/css" href="[% UIThemeFontCSSFile %][% URLReloadPostfix %]"></link>
        <link REL="stylesheet" TYPE="text/css" href="/static/jquery.compiled-min_[% UIThemeName %].css[% URLReloadPostfix %]"></link>

        <link REL="stylesheet" TYPE="text/css" href="/layout/pagecamel_webgui.css[% URLReloadPostfix %]"></link>

        [% FOREACH HeadExtraCS IN HeadExtraCSS %]
            <link rel="stylesheet" href="[% HeadExtraCS %][% URLReloadPostfix %]"  type="text/css">
        [% END %]
        [% FOREACH HeadExtraCS IN HeadExtraCSSNoPostfix %]
            <link rel="stylesheet" href="[% HeadExtraCS %]"  type="text/css">
        [% END %]

        <title>[% IF DisablePageTitleTranslation != "1" %][% tr.trquote(PageTitle) %][% ELSE %][% tr.quote(PageTitle) %][% END %] &#64; [% ProjectNameTitleTag %]</title>

        <!-- favicon stuff, generated by http://realfavicongenerator.net/ -->
        <link rel="apple-touch-icon" sizes="180x180" href="/pics/favicons/apple-touch-icon.png[% URLReloadPostfix %]">
        <link rel="icon" type="image/png" sizes="32x32" href="/pics/favicons/favicon-32x32.png[% URLReloadPostfix %]">
        <link rel="icon" type="image/png" sizes="16x16" href="/pics/favicons/favicon-16x16.png[% URLReloadPostfix %]">
        <link rel="manifest" href="/pics/favicons/manifest.json[% URLReloadPostfix %]">
        <link rel="mask-icon" href="/pics/favicons/safari-pinned-tab.svg[% URLReloadPostfix %]" color="#5bbad5">
        <link rel="shortcut icon" href="/pics/favicons/favicon.ico[% URLReloadPostfix %]">
        <meta name="apple-mobile-web-app-title" content="[% favicon_app_name %]">
        <meta name="application-name" content="[% favicon_app_name %]">
        <meta name="msapplication-config" content="/pics/favicons/browserconfig.xml[% URLReloadPostfix %]">
        <meta name="theme-color" content="#ffffff">
        <!-- end of favicon stuff -->

        <script type="text/javascript" src="/static/jquery.compiled-min.js[% URLReloadPostfix %]"></script>

        [% IF EnableDB == "1" %]
            <script type="text/javascript" src="/static/sqljs/sql-wasm.js[% URLReloadPostfix %]"></script>
        [% END %]

        [% FOREACH HeadExtraScript IN HeadExtraScripts %]
            <script type="text/javascript" src="[% HeadExtraScript %][% URLReloadPostfix %]"></script>
        [% END %]
        [% FOREACH HeadExtraScript IN HeadExtraScriptsNoPostfix %]
            <script type="text/javascript" src="[% HeadExtraScript %]"></script>
        [% END %]
        [% FOREACH HeadExtraModuleScript IN HeadExtraModuleScripts %]
            <script type="module" src="[% HeadExtraModuleScript %][% URLReloadPostfix %]"></script>
        [% END %]
        [% FOREACH HeadExtraModuleScript IN HeadExtraModuleScriptsNoPostfix %]
            <script type="module" src="[% HeadExtraModuleScript %]"></script>
        [% END %]

        <script type="text/javascript">
            var logoutDialog;
            var ttvars = new Object;
            ttvars['trquote'] = new Object;
            ttvars['json'] = new Object;

            $(document).ready(function(){
                // auto-uninline onfoo html tags to JS file
                XX_ON_EVENT_HANDLERS_XX

                // Load tt vars from master template
                loadTTVars('#mastertemplatedataset');
                loadTTVars('#masktemplatedataset');
                loadTTVars('#submasktemplatedataset');
                loadTTVars('#websocketmasktemplatedataset');
                loadTTVars('#autodialogstemplatedataset');

                console.log("PageCamel Version " + ttvars.pagecamelversion);

                $('#mobiledesktopselect_mobile').on('click', function() {
                    document.cookie = "clientMode=mobile; path=/;";
                    window.location.reload();
                    //return false;
                });

                if(ttvars.enablepageviewstats == 1) {
                    _init_pagecamel_pageviewstats();
                }

                // register all "pagecamelnavdestination onclick events
                $('[pagecamelnavdestination]').each(function() {
                    var mndest = $(this).attr('pagecamelnavdestination');
                    $(this).on('click', function() {
                        location.href=mndest;
                    });
                });

                $("select[searchable!='1']").selectmenu({
                    width: 400
                });
                $("select[searchable='1']").each(function() {
                    $(this).width(400);
                    var extendable = false;
                    if($(this).attr('extendable') == '1') {
                        extendable = true;
                    }
                    $(this).select2({
                       tags: extendable
                    });
                });

                $("input[type=checkbox]").checkify({
                    image_checked:'/pics/checkbox_classic_ON.png',
                    image_unchecked:'/pics/checkbox_classic_OFF.png',
                    image_checked_delete:'/pics/checkbox_classic_DELETE.png'
                });

                $("input[displaytype=dateandtime]").datetimepicker({
                    format: 'Y-m-d H:i:s',
                    mask:true,
                });

                $("input[displaytype=dateonly]").datepicker({
                    dateFormat: 'yy-mm-dd',
                    showOn: 'button',
                    buttonImage: '/pics/calendar.gif',
                    buttonImageOnly: true,
                    buttonText: ttvars.trquote.Calendarbutton
                });

                $("input[displaytype=timeonly]").timepicker({
                    timeFormat: 'HH:mm',
                    interval: 30,
                    minTime: '00:00',
                    maxTime: '23:30',
                    startTime: '10:00',
                    dynamic: false,
                    dropdown: true,
                    scrollbar: true
                });

                $("button, input:submit, input:reset, input:button").button();
                $("input.gotobutton[type=button]").gotobutton();

                $("span.cavacnote").cavacnote();

                if(window.extraOnLoadBeforeTables) {
                    extraOnLoadBeforeTables();
                }

                $('#MainDataTable').statictable();
                $('#HelperTable1').statictable();
                $('#HelperTable2').statictable();
                $('#HelperTable3').statictable();
                $('#HelperTable4').statictable();
                $('#HelperTable5').statictable();
                $('#HelperTable6').statictable();
                $('#HelperTable7').statictable();
                $('#HelperTable8').statictable();
                $('#HelperTable9').statictable();
                $('#HelperTable10').statictable();
                $('#HelperTable11').statictable();
                $('#SubHelperTable1').statictable();

                filter_table = $('#MainFilterTable').dataTable({
                            "pagingType": "simple",
                            "stateSave": true, // Save state but we will override the SORTING later
                            "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, ttvars.trquote.All]],
                            "language": {
                                "lengthMenu": ttvars.trquote.Countperpage,
                                "zeroRecords": ttvars.trquote.Nomatches,
                                "info": ttvars.trquote.Recordcount,
                                "infoEmpty": ttvars.trquote.Norecords,
                                "infoFiltered": ttvars.trquote.Maxrecords,
                                "first": ttvars.trquote.First,
                                "last": ttvars.trquote.Last,
                                "paginate": {
                                    "next": "<span class='ui-icon ui-icon-circle-arrow-e'>",
                                    "previous": "<span class='ui-icon ui-icon-circle-arrow-w'>"
                                },
                                "search": ttvars.trquote.Filterresults,
                                "processing": '<img src="/pics/loading_bar.gif' + ttvars.urlreloadpostfix + '">'
                            },
                            "ordering": [],
                            "jQueryUI": true,
                            "autoWidth": false
                        });

                $('#MainFilterDisplayTable').dataTable({
                            "pagingType": "simple",
                            "stateSave": true, // Save state but we will override the SORTING later
                            //"sPaginationType": "full_numbers",
                            "lengthMenu": [[5, 10, 25, 50, -1], [5, 10, 25, 50, ttvars.trquote.All]],
                            "language": {
                                "lengthMenu": ttvars.trquote.Countperpage,
                                "zeroRecords": ttvars.trquote.Nomatches,
                                "info": ttvars.trquote.Recordcount,
                                "infoEmpty": ttvars.trquote.Norecords,
                                "infoFiltered": ttvars.trquote.Maxrecords,
                                "first": ttvars.trquote.First,
                                "last": ttvars.trquote.Last,
                                "paginate": {
                                    "next": "<span class='ui-icon ui-icon-circle-arrow-e'>",
                                    "previous": "<span class='ui-icon ui-icon-circle-arrow-w'>"
                                },
                                "search": ttvars.trquote.Filterresults
                            },
                            "ordering": [],
                            "jQueryUI": true,
                            "autoWidth": false
                        });


                if(filter_table) {
                    // change back to native server side sorting
                    filter_table.fnSortNeutral();

                    // Add special submit function to hide the table and restore hidden rows
                    $('#MainFilterForm').on('submit', function(){
                        document.getElementById('pagecamelMenuContent').style.display = 'none';
                        document.getElementById('pagecamelPageContent').style.display = 'none';
                        document.getElementById('pagecamelFooterContent').style.display = 'none';
                        document.getElementById('pagecamelSendingContent').style.display = 'block';

                        $(filter_table.fnGetHiddenNodes()).appendTo(this);

                        return true;
                    });
                }

                $( "#menutabs, #submenutabs" ).buttonset();

                $("a[activemenutab='1']").each(function() {
                    $(this).addClass('ui-state-active');
                    $(this).on('mouseleave',function() {
                        $(this).addClass('ui-state-active');
                    });
                });

                $( "#dialog-logout" ).dialog({
                    autoOpen: false,
                    resizable: false,
                    modal: true,
                    width: 400,
                    height: 600,
                    buttons: [
                        {
                            text: ttvars.trquote.Logout,
                            click: function() {
                                location.href="/user/logout";
                            }
                        },
                        {
                            text: ttvars.trquote.Close,
                            click: function() {
                                $( this ).dialog( "close" );
                            }
                        }
                    ]
                });


                $( "#dialog-whoami" ).dialog({
                    autoOpen: false,
                    resizable: false,
                    modal: true,
                    width: 600,
                    height: 350,
                    buttons: [
                        {
                            text: ttvars.trquote.Close,
                            click: function() {
                                $( this ).dialog( "close" );
                            }
                        }
                    ]
                });

                if(ttvars.isaprilfoolsday == "1") {
                    $( "#dialog-aprilfool" ).dialog({
                        autoOpen: false,
                        resizable: false,
                        modal: true,
                        width: 600,
                        height: 350,
                        buttons: [
                            {
                                text: ttvars.trquote.Close,
                                click: function() {
                                    $( this ).dialog( "close" );
                                }
                            }
                        ]
                    });
                }

                // AutoDialogs
                if(window.JSinitTTDialogs) {
                    JSinitTTDialogs();
                }

                document.getElementById('pagecamelLoadingContent').style.display = 'none';
                document.getElementById('pagecamelMenuContent').style.display = 'block';
                document.getElementById('pagecamelPageContent').style.display = 'block';
                document.getElementById('pagecamelFooterContent').style.display = 'block';


                $('#sidebar_menu').menu();

                $('#top_menu').menu();
                  
                $('#top_menu').menu({
                    position: { my: 'left top', at: 'left bottom' },
                    blur: function() {
                        $(this).menu('option', 'position', { my: 'left top', at: 'left bottom' });
                    },
                    focus: function(e, ui) {
                        if ($('#top_menu').get(0) !== $(ui).get(0).item.parent().get(0)) {
                            $(this).menu('option', 'position', { my: 'left top', at: 'right top' });
                        }
                    },
                });



                // If appropriate, start the computer map
                if(window.startMap) {
                    startMap();
                }

                if(window.extraOnLoad) {
                    extraOnLoad();
                }

                $( "#tabs" ).tabs();

                if(ttvars.webappshoweyes == "1") {
                    $('.iris').xeyes();

                    function blinkeyeClose() {
                        $('.eye').css('background-color', '#000000');
                        window.setTimeout(blinkeyeOpen, 150);
                    }
                    function blinkeyeOpen() {
                        $('.eye').css('background-color', '#FFFFFF');
                        window.setTimeout(blinkeyeClose, 14000);
                    }
                    window.setTimeout(blinkeyeClose, 10000);
                }

                if(window.lateExtraOnLoad) {
                    lateExtraOnLoad();
                }

                if(ttvars.pagetitle != "Login" && ttvars.pagetitle != "Logout" && ttvars.pagetitle != "Reset Password" && ttvars.ispublicurl != "1") {
                    startSessionRefresh('lastsessionrefresh', '/user/sessionrefresh');
                }

                if(ttvars.webappshowsanta == "1") {
                    $('#santa').sprite({fps: 8, no_of_frames: 8}).spState(1);
                    $('#santa').animate({
                        left: "50px"
                    }, 12000);
                }

                if(ttvars.webappusemousetrail == "1") {
                    $(document.body).cursorTrail({
                        "class": "cursor-trail-color"
                    });
                }

                if(ttvars.animatedprojectlogo == "1") {
                    projectlogoInit();
                }

                if(ttvars.setdocumenthref !== "") {
                    document.location.href = ttvars.setdocumenthref;
                }

                if(ttvars.focusonfield !== "") {
                    $(ttvars.focusonfield).focus();
                }

                // Fix button fonts
                $('.ui-button').each(function() {
                    $(this).css('font-family', ttvars.fontface);
                });

                if(ttvars.keyfoblogout == "1") {
                    setInterval(runFobLogoutReader, 1000);
                }

                if(ttvars.enabledb == "1") {
                    pagecamelDBInit();
                }


            });

            var foblogoutreader = new XMLHttpRequest();
            var foblogoutrunning = 0;
            function runFobLogoutReader() {
                if(foblogoutrunning == 1) {
                    return;
                }
                foblogoutreader.open("GET", 'http://localhost:8080', true);
                foblogoutreader.onreadystatechange=function() {
                    if(foblogoutreader.readyState == 4) {
                        var newfob = foblogoutreader.responseText;
                        if(newfob == '') {
                            console.log("Starting FOB logout...");
                            foblogoutrunning = 1;
                            $.blockUI({ message: '<h1>' + ttvars.trquote.Keyfoblogout + '<br/><img src="/pics/loading_bar_large.gif' + ttvars.urlreloadpostfix + '" /></h1>' });
                            location.href="/user/logout";
                        }
                    }
                }
                foblogoutreader.send(null);
            }


            function ShowAprilFools() {
                document.getElementById('alientransmission').play();
                $( "#dialog-aprilfool" ).dialog("open");
            }


            function CheckLogout() {
                if(ttvars.isaprilfoolsday == "1") {
                    document.getElementById('alientransmission').play();
                }
                $( "#dialog-logout" ).dialog("open");

            }

            function showWhoami() {
                if(ttvars.isaprilfoolsday == "1") {
                    document.getElementById('alientransmission').play();
                }
                $( "#dialog-whoami" ).dialog("open");
                return false;
            }

            function SQLtoBinArray(str) {
                var l = str.length,
                    arr = new Uint8Array(l);
                for (var i = 0; i < l; i++) {
                    arr[i] = str.charCodeAt(i);
                }
                return arr;
            }

            function SQLtoBinString(arr) {
                var uarr = new Uint8Array(arr);
                var strings = [], chunksize = 0xffff;
                // There is a maximum stack size. We cannot call String.fromCharCode with as many arguments as we want
                for (var i = 0; i * chunksize < uarr.length; i++) {
                    strings.push(String.fromCharCode.apply(null, uarr.subarray(i * chunksize, (i + 1) * chunksize)));
                }
                return strings.join('');
            }

            var pagecameldb;
            var pagecameldbloaded = 0;

            function pagecamelDBInit() {
                console.log("pagecamelDBInit called **************************************");

                var baseUrl = '/static/sqljs/';

                // Normally Sql.js tries to load sql-wasm.wasm relative to the page, not relative to the javascript
                // doing the loading. So, we help it find the .wasm file with this function.
                var fname = baseUrl + 'sql-wasm.wasm';
                var config = {
                    locateFile: filename => fname
                };
                initSqlJs(config).then(function (SQL) {
                    var dbstr = window.localStorage.getItem("pagecamel.sqlite");
                    if (dbstr) {
                        pagecameldb = new SQL.Database(SQLtoBinArray(dbstr));
                    } else {
                        pagecameldb = new SQL.Database();
                        pagecamelDBSave();
                    }
                    pagecameldbloaded = 1;
                    console.log("************************     Database loaded");
                    if(window.PagecamelDBOnLoad) {
                        PagecamelDBOnLoad();
                    }
                });
            }

            function pagecamelDBSave() {
                var dbstr = SQLtoBinString(pagecameldb.export());
                window.localStorage.setItem("pagecamel.sqlite", dbstr);
            }

        </script>

        [% IF ExtraHEADElements %]
            [% ExtraHEADElements %]
        [% END %]

        [% IF AdsHeaderCode != '' %]<!-- For Adblock remove code below -->
        [% AdsHeaderCode %]
        <!-- For Adblock remove code above -->[% END %]

    </head>
    <body>
        <!-- master template TT vars dataset -->
        <span id="mastertemplatedataset"
            data-pagecamelversion="[% PageCamelVersion %]"
            data-isaprilfoolsday="[% IsAprilFoolsDay %]"
            data-urlreloadpostfix="[% URLReloadPostfix %]"
            data-lastreloaddate="[% LastReloadDate %]"
            data-webappshoweyes="[% WebAppShowEyes %]"
            data-webappshowsanta="[% WebAppShowSanta %]"
            data-webappusemousetrail="[% WebAppUseMouseTrail %]"
            data-pagetitle="[% PageTitle %]"
            data-ispublicpage="[% IsPublicPage %]"
            data-setdocumenthref="[% SetDocumentHREF %]"
            data-focusonfield="[% FocusOnField %]"
            data-mobiledesktopclientmode="[% MobileDesktopClientMode %]"
            data-animatedprojectlogo="[% AnimatedProjectLogo %]"
            data-trquote-all="[% tr.trquote("All") %]"
            data-trquote-countperpage="[% tr.trquote("Display _MENU_ records per page") %]"
            data-trquote-nomatches="[% tr.trquote("No matches found") %]"
            data-trquote-recordcount="[% tr.trquote("Showing _START_ to _END_ of _TOTAL_ records") %]"
            data-trquote-norecords="[% tr.trquote("Showing 0 to 0 of 0 records") %]"
            data-trquote-maxrecords="[% tr.trquote("(filtered from _MAX_ total records)") %]"
            data-trquote-first="[% tr.trquote("First") %]"
            data-trquote-last="[% tr.trquote("Last") %]"
            data-trquote-filteresults="[% tr.trquote("Filter results") %]"
            data-trquote-logout="[% tr.trquote("Logout") %]"
            data-trquote-cancel="[% tr.trquote("Cancel") %]"
            data-trquote-close="[% tr.trquote("Close") %]"
            data-trquote-calendarbutton="[% tr.trquote("Select Date") %]"
            data-enablepageviewstats="[% EnablePageViewStats %]"
            data-enabledb="[% EnableDB %]"
            data-fontfamily="[% UIThemeFont %]"
            data-fontface="[% UIThemeFontFace %]"
            data-keyfoblogout="[% userData.keyfob_logout %]"
            data-trquote-keyfoblogout="[% tr.trquote("Key fob logout...") %]"
        ></span>
        <!-- master template TT vars dataset -->


        [% IF header_info %]
            <div class="webgui_headerinfo">[% header_info %]</div>
        [% END %]

        [% IF header_message %]
            <div class="webgui_headermessage">
                <div class="webgui_headermessage_left"><img src="/pics/hackman2.gif"></div>
                <div class="webgui_headermessage_middle">[% header_message %]</div>
                <div class="webgui_headermessage_right"><img src="/pics/hackman2.gif"></div>
            </div>
        [% END %]


        <div class="webgui_projectbar">

            [% IF AnimatedProjectLogo == "1" %]
                <div class="webgui_projectname"><canvas id="logoCanvas" width="80" height="80"></canvas></div>
            [% END %]

            <div class="webgui_projectname">[% ProjectName %]</div>

            [% IF WebAppShowEyes == "1" %]
                <div class="webgui_watching_eyes">
                    <div class="eye">
                        <div class="iris"></div>
                    </div>
                    <div class="eye">
                        <div class="iris"></div>
                    </div>
                </div>
            [% ELSE %]
                <div class="webgui_insteadofeyes_spacer">&nbsp;</div>
            [% END %]
            <div class="webgui_projectmottobar">
                <div class="webgui_projectmottotext">[% ProjectMotto %]</div>
                <div class="webgui_projectloginlink">
                    [% IF userData.user == '' || userData.user == 'guest' %]
                        <a class="webgui_projectloginlink" href="/user/login">[% tr.trquote("Login") %]</a>
                        [% IF canRegisterUsers == 1 %]
                            / <a class="webgui_projectloginlink" href="/user/register">[% tr.trquote("Register") %]</a>
                        [% END %]
                    [% ELSE %]
                        [% IF userData.keyfob_logout %]<i>[% END %]
                        [% IF IsAprilFoolsDay == "1" %]
                            <div class="webgui_projectusername">The great and powerful [% tr.quote(userData.first_name) %]&nbsp;/&nbsp;
                        [% ELSE %]
                            <div class="webgui_projectusername">[% tr.quote(userData.first_name) %] [% tr.quote(userData.last_name) %][% IF userData.headerinfo != "" %] [% tr.quote(userData.headerinfo) %][% END %]&nbsp;/&nbsp;
                        [% END %]
                        <a class="webgui_projectloginlink" href="/user/logout" onClick="CheckLogout(); return false;">[% tr.trquote("Logout") %]</a>
                        [% IF userData.hasrealuser == 1 %]
                            / <a class="webgui_projectloginlink" href="/user/switchback">[% tr.trquote("Back") %]</a>
                        [% END %]
                        </div>
                        [% IF userData.keyfob_logout %]</i>[% END %]
                    [% END %]
                </div>
            </div>
        </div>

        [% IF MobileDesktopClientMode != '' %]
            <!--
            <div class="pagecamelmobiledesktopselectorbox">
                [% IF MobileDesktopClientMode == 'desktop' %]
                    [% tr.trquote('You are viewing the desktop version of this site.') %]
                    <a href="" id="mobiledesktopselect_mobile">[% tr.trquote("Click here to select the mobile version.") %]</a>
                [% END %]
            </div>
            -->
        [% END %]


    <div id="pagecamelLoadingContent" class="elem_display_block">
        <p align="center">
            <div class="infotext">[% tr.trquote("Please wait...") %]</div><br>
            <div align="center"><img src="/pics/loading_doublerings.gif[% URLReloadPostfix %]"></div>
        </p>
    </div>

    <div id="pagecamelSendingContent" class="elem_display_none">
        <p align="center">
            <div class="infotext">[% tr.trquote("Please wait...") %]</div><br>
            <div align="center"><img src="/pics/loading_bar_large.gif[% URLReloadPostfix %]"></div>
        </p>
    </div>

    [% IF AdsSidebarCode != '' %]
    <table border="0"  align="center" cellpadding="10" width="100%">
        <tr>
            <td>
    [% END %]
    <div id="pagecamelMenuContent" class="elem_display_none" width="100%" align="center" valign="top" border="0">
        [% IF HideMenuBar == "1" %]
            <!-- No menu bar in this window -->
        [% ELSE %]
            [% IF PageTitle == "Login" || PageTitle == "Logout" || PageTitle == "Reset Password" || PageTitle == "Register new account" || webpath == PIMenuPublicUrl %]
                <br/>
                <table border="0" cellpadding="0" cellspacing="0" class="header" align="center" width="100%">
                    <tr>
                        <td width="*">&nbsp;</td>
                        <td>
                            <table border="0" cellpadding="2" cellspacing="0" class="header" align="center">
                                <tr>
                                    <td align="center">
                                        <!-- *** QuickNav *** -->
                                        <div id="menutabs">
                                            <!-- login -->
                                            <a id="login_button" name="menutab" href="/user/login" pagecamelnavdestination="/user/login"
                                                [% IF PageTitle == "Login" %]activemenutab="1"[% END %]>
                                                [% tr.trquote("Login") %][% IF PageTitle == "Login" %]*[% END %]
                                            </a>
                                            [% IF canResetPassword == 1 %]
                                            <a id="reset_password_button" name="menutab" href="/user/pwreset" pagecamelnavdestination="/user/pwreset"
                                                [% IF PageTitle == "Reset Password" %]activemenutab="1"[% END %]>
                                                [% tr.trquote("Reset password") %][% IF PageTitle == "Reset Password" %]*[% END %]
                                            </a>
                                            [% END %]
                                            [% IF canRegisterUsers == 1 %]
                                                <a id="register_account_button" name="menutab" href="/user/register" pagecamelnavdestination="/user/register"
                                                    [% IF PageTitle == "Register new account" %]activemenutab="1"[% END %]>
                                                    [% tr.trquote("Register") %][% IF PageTitle == "Register new account" %]*[% END %]
                                                </a>
                                            [% END %]
                                            [% IF webpath == PIMenuPublicUrl %]
                                                <a id="pimenu_button" name="menutab" href="[% PIMenuPublicUrl %]" pagecamelnavdestination="[% PIMenuPublicUrl %]"
                                                    activemenutab="1">
                                                    &Pi;
                                                </a>
                                            [% END %]
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                        <td width="*">&nbsp;</td>
                    </tr>
                </table>
            [% ELSE %]
                [% IF DropDownMenuCount != "" AND DropDownMenuCount > 1 AND UIMenubarName == "top" %]
                    <table border="0" class="menutable" align="center" valign="top">
                        <tr align="center">
                            <td valign="top" align="center">
                                <!-- **** DROP DOWN MENU *** -->
                                <ul id="top_menu">
                                    [% FOREACH menu IN DropDownMenu %]
                                        [% IF menu.type == "submenustart" %]
                                            <li align="left"><div>[% tr.trquote(menu.title) %]</div>
                                                <ul>
                                        [% ELSIF menu.type == "submenuend" %]
                                                </ul>
                                             </li>
                                        [% ELSE %]
                                             <li><div align="left"><!--<a href="[% menu.defaultpath %]">-->[% tr.trquote(menu.title) %]<!--</a>--></div>
                                                <ul>
                                                    [% FOREACH menuitem IN menu.items %]
                                                        <li align="left"><a href="[% menuitem.path %]">[% tr.trquote(menuitem.title) %]</a></li>
                                                    [% END %]
                                                </ul>
                                            </li>
                                        [% END %]
                                    [% END %]
                                </ul>
                            </td>
                            <td width="*">&nbsp;</td>
                        </tr>
                    </table>
                [% ELSE %]
                    <br/>
                [% END %]
                [% IF QuickNavBar.size > 1 %]
                    <table border="0" cellpadding="0" cellspacing="0" class="header" align="center" width="100%">
                        <tr>
                            <td width="*">&nbsp;</td>
                            <td>

                                <table border="0" cellpadding="0" cellspacing="0" class="header" align="center">
                                    <tr>
                                        <td valign="center" align="center">
                                            <!-- *** QuickNav *** -->
                                            <div id="menutabs">
                                                [% FOREACH navItem IN QuickNavBar %]
                                                    <a id="[% tr.quote(navItem.title) %]" name="menutab" href="[% navItem.path %]" pagecamelnavdestination="[% navItem.path %]"
                                                    [% IF navItem.active == 1 %]activemenutab="1"[% END %]>
                                                        [% tr.trquote(navItem.title) %][% IF navItem.active == 1 %]*[% END %]
                                                    </a>
                                                [% END %]
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                            <td width="*">&nbsp;</td>
                        </tr>
                    </table>
                [% END %]
            [% END %]
        [% END %]
    </div>

    [% IF AdsSidebarCode != '' %]
    <table border="0"  align="center" cellpadding="10" width="100%">
        <tr>
            <td>
    [% END %]
                <div id="pagecamelPageContent" class="elem_display_none" width="100%" align="center" valign="top" border="0">
                    [% IF DropDownMenuCount != "" AND DropDownMenuCount > 1 AND UIMenubarName == "sidebar" %]
                        <table border="0"  align="center" cellpadding="10" width="100%">
                            <tr>
                                <td width="100px" valign="top">
                                    <ul id="sidebar_menu">
                                        [% FOREACH menu IN DropDownMenu %]
                                            [% IF menu.type == "submenustart" %]
                                                <li><div>[% tr.trquote(menu.title) %]</div>
                                                    <ul>
                                            [% ELSIF menu.type == "submenuend" %]
                                                    </ul>
                                                 </li>
                                            [% ELSE %]

                                                <li><div><!--<a href="[% menu.defaultpath %]">-->[% tr.trquote(menu.title) %]<!--</a>--><br/></div>

                                                    <ul>
                                                        [% FOREACH menuitem IN menu.items %]
                                                            <li><a href="[% menuitem.path %]">[% tr.trquote(menuitem.title) %]</a></li>
                                                        [% END %]
                                                    </ul>

                                                </li>
                                            [% END %]
                                        [% END %]
                                    </ul>
                                </td>
                                <td align="center" valign="top">
                    [% END %]

                                    <table border="0"  align="center" cellpadding="10">
                                        <tr>
                                            <td width="100%">
                                                <div id="dataarea" name="dataarea" align="center">
                                                    XX_BODY_XX
                                                </div>
                                            </td>
                                        </tr>
                                    </table>
                    [% IF DropDownMenuCount != "" AND DropDownMenuCount > 1 AND UIMenubarName == "sidebar" %]
                                </td>
                                <td width="100px" valign="top"></td>
                            </tr>
                        </table>
                    [% END %]
    [% IF AdsSidebarCode != '' %]
            </td>
            <td width="200px">
               <!-- For Adblock remove code below -->
                [% AdsSidebarCode %]
                <!-- For Adblock remove code above -->
            </td>
            <td width="100px">
                &nbsp;
            </td>
        </tr>
    </table>
    [% END %]

                </div>
    <div id="pagecamelFooterContent" class="elem_display_none" width="100%" align="center" valign="top" border="0">

        <br>

        <table class="footer" width="400px" align="right" valign="top" border="0">
            <tr>
                <td colspan="3" height="20px">&nbsp;</td>
            </tr>

            <tr>
                <td colspan="1"></td>
                <td>Doc. created</td>
                <td colspan="1">[% CurrentTime %]</td>
            </tr>
            <tr>
                <td colspan="1" align="left">
                    [% IF PrivacyPolicyURL != '' %]
                        <a href="[% PrivacyPolicyURL %]" target="_blank">[% tr.trquote("Privacy Policy") %]</a>
                    [% END %]
                </td>
                <td colspan="1" align="left">
                    [% IF ImpressumURL != '' %]
                        <a href="[% ImpressumURL %]" target="_blank">[% tr.trquote("Contact/Impressum") %]</a>
                    [% END %]
                </td>
                <td colspan="1" align="left">
                    <a href="#" onclick="return showWhoami();">[% tr.trquote("Session information") %]</a>
                </td>
            </tr>
            [% IF EnablePIMenu == 1 && webpath != PIMenuPublicUrl %]
            <tr>
                <td colspan="3">
                    <p align="right" target="_new"><a href="[% PIMenuPublicUrl %]">&Pi;</a></p>
                </td>
            </tr>
            [% END %]
        </table>

        [% IF BrowserData %]
        <!-- BrowserWorkarounds activated for:
            Browser: [% BrowserData.Browser %]
            Browser detection from UserAgent string [% BrowserData.UserAgent %]
        -->
        [% END %]


        <!-- Logout dialog -->
        <div id="dialog-logout" title="Logout?">
            <p><span class="ui-icon ui-icon-alert defaultlayout_logouticon"></span>[% tr.trquote("Do you really want to close this session?") %]</p>
        </div>

        <!-- Whoami dialog -->
        <div id="dialog-whoami" title="[% tr.trquote("Logon session information") %]">
            <p>
                <span>
                    [% IF userData.user == 'guest' %]
                        [% tr.trquote("You are not logged on.") %]<br/>
                        &nbsp;<br/>
                        [% tr.trquote("Please login or register.") %]
                    [% ELSE %]
                        [% tr.trquote("Username") %]: [% userData.user %]<br/>
                        [% tr.trquote("First name") %]: [% tr.quote(userData.first_name) %]<br/>
                        [% tr.trquote("Last name") %]: [% tr.quote(userData.last_name) %]<br/>
                        [% tr.trquote("Email") %]: [% tr.quote(userData.email_addr) %]
                    [% END %]
                </span>
            </p>
        </div>

        [% IF WebAppShowSanta == "1" %]
            <div id="santa"></div>
        [% END %]

        [% IF IsAprilFoolsDay == "1" %]
            <div id="dialog-aprilfool" title="Datumserinnerung">
                <p>
                    <span>
                        <p align="center"></p><img src="/pics/1st_april.png"></p>
                    </span>
                </p>
            </div>
        [% END %]

    </div>

    [% IF IsAprilFoolsDay == "1" %]
        <audio id="alientransmission">
            <source src="/static/aprilfools/alientransmission.ogg" type="audio/ogg">
            <source src="/static/aprilfools/alientransmission.mp3" type="audio/mpeg">
            <source src="/static/aprilfools/alientransmission.wav" type="audio/wav">
        </audio>
    [% END %]

    [% IF PAGECAMELPAGEFOOTERTEXT != "" %]
        <div id="pagecamelpagefooter" class="pagecamelpagefooter_[% PAGECAMELPAGEFOOTERCOLOR %]">[% PAGECAMELPAGEFOOTERTEXT %]</div>
    [% END%]

    <div class="stars"></div>
    <!--<div class="twinkling"></div>-->
    </body>
</html>
