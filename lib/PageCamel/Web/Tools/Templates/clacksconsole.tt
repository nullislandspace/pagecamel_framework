<p align="left">
    <canvas id="debuglogcanvas" width="1300px" height="800px"></canvas><br/>
    <input type="input" maxLength="3000" id="cmdinput">
</p>
[% tr.trquote("Copy&Paste") %]: <input type="input" size="100" name="copypaste"><br/>
[% tr.trquote("Enable updates") %]: <input type="checkbox" name="enableUpdate" checked="checked"><br/>
<span id="masktemplatedataset"
    data-webappusegst="[% WebAppUseGST %]"
></span>


<script>
    var lines = new Array;
    var oldlines1 = new Array;
    var oldlines2 = new Array;
    var oldlines3 = new Array;
    var oldlines4 = new Array;
    var oldlines5 = new Array;
    var oldlines6 = new Array;
    var oldlines7 = new Array;
    var maxlinelength;

    function websocketmaskOnload() {
        if(ttvars.webappusegst == "1") {
            maxlinelength = 32;
            $('#cmdinput').addClass('consoleinput_gst');
        } else {
            maxlinelength = 48;
            $('#cmdinput').addClass('consoleinput_nogst');
        }

        $('#cmdinput').keyup(function(event) {
            if(event.keyCode === 13) {
                var cmd = $('#cmdinput').val();
                $('#cmdinput').val('');
                if(lines.length > maxlinelength) {
                    lines.shift();
                }
                lines.push(cmd);
                var cmdmsg = {
                    type: 'CLACKS',
                    command: cmd
                };
                ws.send(JSON.stringify(cmdmsg));
            }
        });
    }

    function websocketmaskOnSocketOpen() {
        if(ttvars.webappusegst == "1") {
            paintCanvas_gst();
            $('#debuglogcanvas').click(canvasClicks_gst);
        } else {
            paintCanvas_nogst();
            $('#debuglogcanvas').click(canvasClicks_nogst);
        }
    }


    function handleMessage(msg) {
        if(msg.type === "CLACKSLINE") {

            if(getEnableStatus()) {
                if(lines.length > maxlinelength) {
                    lines.shift();
                }
                lines.push(msg.cmd);
            }

            return;
        }

    }

    function paintCanvas_nogst() {

        var canvas = document.getElementById('debuglogcanvas');
        var ctx = canvas.getContext('2d');

        ctx.font="normal normal lighter 16px Courier";

        // Background
        ctx.fillStyle = '#000000';
        ctx.strokeStyle = '#C0C0C0';
        ctx.fillRect(0, 0, 1300, 800);
        ctx.strokeRect(0, 0, 1300, 800);

        // Lines
        ctx.fillStyle = '#FFFFFF';
        for(i = 0; i < lines.length; i++) {
            ctx.fillText(lines[i], 10, 20 + (i * 16));
        }

        setTimeout(paintCanvas_nogst, 40);
    }


    function canvasClicks_nogst(e) {
        var x = Math.floor((e.pageX-$("#debuglogcanvas").offset().left));
        var y = Math.floor((e.pageY-$("#debuglogcanvas").offset().top));

        var linenum = y - 9;
        if(linenum < 0) {
            return;
        }
        linenum = Math.floor(linenum / 16);

        if(linenum >= lines.length) {
            $('input[name="copypaste"]').val('');
            return;
        }

        $('input[name="copypaste"]').val(lines[linenum]);

    }

    function paintCanvas_gst() {

        var canvas = document.getElementById('debuglogcanvas');
        var ctx = canvas.getContext('2d');

        ctx.font="normal normal lighter 20px Courier";

        // Background
        ctx.fillStyle = '#000000';
        ctx.fillRect(0, 0, 1300, 800);

        // fading text lines
        ctx.fillStyle = '#001000';
        for(i = 0; i < oldlines7.length; i++) {
            ctx.fillText(oldlines7[i], 10, 30 + (i * 24));
        }
        oldlines7 = oldlines6.slice();

        ctx.fillStyle = '#003000';
        for(i = 0; i < oldlines6.length; i++) {
            ctx.fillText(oldlines6[i], 10, 30 + (i * 24));
        }
        oldlines6 = oldlines5.slice();

        ctx.fillStyle = '#005000';
        for(i = 0; i < oldlines5.length; i++) {
            ctx.fillText(oldlines5[i], 10, 30 + (i * 24));
        }
        oldlines5 = oldlines4.slice();


        ctx.fillStyle = '#007000';
        for(i = 0; i < oldlines4.length; i++) {
            ctx.fillText(oldlines4[i], 10, 30 + (i * 24));
        }
        oldlines4 = oldlines3.slice();

        ctx.fillStyle = '#009000';
        for(i = 0; i < oldlines3.length; i++) {
            ctx.fillText(oldlines3[i], 10, 30 + (i * 24));
        }
        oldlines3 = oldlines2.slice();

        ctx.fillStyle = '#00b000';
        for(i = 0; i < oldlines2.length; i++) {
            ctx.fillText(oldlines2[i], 10, 30 + (i * 24));
        }
        oldlines2 = oldlines1.slice();

        ctx.fillStyle = '#00d000';
        for(i = 0; i < oldlines1.length; i++) {
            ctx.fillText(oldlines1[i], 10, 30 + (i * 24));
        }
        oldlines1 = lines.slice();

        // Text Lines
        ctx.fillStyle = '#A0FFA0';
        for(i = 0; i < lines.length; i++) {
            ctx.fillText(lines[i], 10, 30 + (i * 24));
        }

        // CRT raster lines
        //ctx.fillStyle = '#FFFFFF';
        ctx.strokeStyle = '#000000';
        ctx.lineWidth=1;
        for(i = 0; i < 800; i+=3) {
            //ctx.strokeRect(0, i, 1000, i+1);
            ctx.beginPath();
            ctx.moveTo(0, i);
            ctx.lineTo(1299, i);
            ctx.stroke();
        }



        setTimeout(paintCanvas_gst, 40);
    }


    function canvasClicks_gst(e) {
        var x = Math.floor((e.pageX-$("#debuglogcanvas").offset().left));
        var y = Math.floor((e.pageY-$("#debuglogcanvas").offset().top));

        var linenum = y - 19;
        if(linenum < 0) {
            return;
        }
        linenum = Math.floor(linenum / 24);

        if(linenum >= lines.length) {
            $('input[name="copypaste"]').val('');
            return;
        }

        $('input[name="copypaste"]').val(lines[linenum]);

    }

    function getEnableStatus() {
        var myval = $('input[name="enableUpdate"]').val();
        if(myval != 'on') {
            return false;
        }
        return true;
    }
</script>
