<form name="translations" method="post" action="[% webpath %]"  id="MainFilterForm">
    <p align="center">    
        <table class="data" align="center" id="MainFilterTable">
            <thead>
                <tr class="tabheader">
                    <th></th>
                    <th>[% tr.trquote("Name") %]</th>
                    <th>[% tr.trquote("Screenshot") %]</th>
                    <th>[% tr.trquote("Description") %]</th>
                </tr>
            </thead>
            <tbody>
                [% FOREACH Menubar IN AvailMenubars %]
                    <tr>
                        <td>
                            <input type="radio" name="menubar" value="[% tr.quote(Menubar.menubar) %]"
                            [% IF Menubar.menubar == UIMenubarName %]
                                checked="checked"
                            [% END %]
                            >
                        </td>
                        <td>
                            [% tr.trquote(Menubar.name) %]
                        </td>
                        <td>
                            <img src="[% tr.quote(Menubar.screenshot) %]" alt="Screenshot [% tr.trquote(Menubar.name) %]"  width="250px" height="175px">
                        </td>
                        <td width="200px">
                            [% tr.trquote(Menubar.description) %]
                        </td>
                    </tr>
                [% END %]
            </tbody>
        </table>
    </p>
  
    <p align="center">
        <input type="hidden" name="mode" value="setvalue">
        <input type="submit" value="[% tr.trquote("Select") %]">
    </p>
</form>
