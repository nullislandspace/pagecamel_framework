<div align="left">
    <h1>WaterFeeler live view</h1>
    <p><div class="errortext">Note: This probe is currently running pre-launch system tests.</div></p>
    <p>
        This is the live data from the WaterFeeler GardenSpaceProgram mission. Depending on circumstances, this might not always update.<br/>
        You do <em>not</em> have to reload the page, when new data comes in, it will update automatically.
    </p>
    <p>
        WaterFeeler is a "space probe" with the goal to detect ground water and precipitation.
        <a href="/guest/blog/view/96">this blog article</a> for more details.
    </p>

    <p>
        <table border="1">
            <tr>
                <td>

                    <table class="data">
                        <thead>
                            <tr class="tabheader">
                                <th colspan="2" class="statichead">System status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="staticeven">
                                <td>Last update</td>
                                <td><span class="livedata" sensorname="liveview_status_timestamp"></span></td>
                            </tr>
                            <tr class="staticodd">
                                <td>Uptime (milliseconds)</td>
                                <td align="right"><span class="livedata" sensorname="liveview_ticks"></span></td>
                            </tr>
                            <tr class="staticeven">
                                <td>Free memory (bytes)</td>
                                <td align="right"><span class="livedata" sensorname="liveview_memfree"></span></td>
                            </tr>
                            <tr class="staticodd">
                                <td>Packets in</td>
                                <td align="right"><span class="livedata" sensorname="liveview_packets_in"></span></td>
                            </tr>
                            <tr class="staticeven">
                                <td>Packets out</td>
                                <td align="right"><span class="livedata" sensorname="liveview_packets_out"></span></td>
                            </tr>
                            <tr class="staticodd">
                                <td>Battery Volt (raw value)</td>
                                <td align="right"><span class="livedata" sensorname="liveview_voltage_raw"></span></td>
                            </tr>
                            <tr class="staticeven">
                                <td>Battery Volt (calculated)</td>
                                <td align="right"><span class="livedata" sensorname="liveview_voltage_calculated"></span></td>
                            </tr>
                        </tbody>
                    </table>
                </td>
                <td>
                    <table class="data">
                        <thead>
                            <tr class="tabheader">
                                <th colspan="2" class="statichead">Waterfeeler Soil sensor<br/>(resistive divider)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="staticeven">
                                <td>Last update</td>
                                <td><span class="livedata" sensorname="liveview_waterfeeler_timestamp"></span></td>
                            </tr>
                            <tr class="staticodd">
                                <td>no pulldown (floating)</td>
                                <td align="right"><span class="livedata" sensorname="liveview_volt_floating"></span></td>
                            </tr>
                            <tr class="staticeven">
                                <td>470 &#x2126; pulldown</td>
                                <td align="right"><span class="livedata" sensorname="liveview_volt_470ohm"></span></td>
                            </tr>
                            <tr class="staticodd">
                                <td>1k &#x2126; pulldown</td>
                                <td align="right"><span class="livedata" sensorname="liveview_volt_1kohm"></span></td>
                            </tr>
                            <tr class="staticeven">
                                <td>10k &#x2126; pulldown</td>
                                <td align="right"><span class="livedata" sensorname="liveview_volt_10kohm"></span></td>
                            </tr>
                            <tr class="staticodd">
                                <td>100k &#x2126; pulldown</td>
                                <td align="right"><span class="livedata" sensorname="liveview_volt_100kohm"></span></td>
                            </tr>
                            <tr class="staticeven">
                                <td>1M &#x2126; pulldown</td>
                                <td align="right"><span class="livedata" sensorname="liveview_volt_1mohm"></span></td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>
            <tr>
                <td>
                    <table class="data">
                        <thead>
                            <tr class="tabheader">
                                <th colspan="3" class="statichead">Digital Temperature and Humidity (DHT)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="staticeven">
                                <td>Last update</td>
                                <td colspan="2"><span class="livedata" sensorname="liveview_dht_timestamp"></span></td>
                            </tr>
                            <tr class="staticodd">
                                <td>Internal Sensor</td>
                                <td align="right"><span class="livedata" sensorname="liveview_internal_temperature"></span>&#176;C</td>
                                <td align="right"><span class="livedata" sensorname="liveview_internal_humidity"></span>&#37;</td>
                            </tr>
                            <tr class="staticeven">
                                <td>External Sensor</td>
                                <td align="right"><span class="livedata" sensorname="liveview_external_temperature"></span>&#176;C</td>
                                <td align="right"><span class="livedata" sensorname="liveview_external_humidity"></span>&#37;</td>
                            </tr>
                        </tbody>
                    </table>
                </td>
                <td>
                    <table class="data">
                        <thead>
                            <tr class="tabheader">
                                <th colspan="2" class="statichead">Rain sensor<br/>(water level sensor in cup)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="staticeven">
                                <td>Last update</td>
                                <td><span class="livedata" sensorname="liveview_waterfeeler_timestamp"></span></td>
                            </tr>
                            <tr class="staticodd">
                                <td>Waterlevel (raw)</td>
                                <td align="right"><span class="livedata" sensorname="liveview_waterlevel"></span></td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>
        </table>
    </p>

    <p>
        <table class="data">
            <thead>
                <tr class="tabheader">
                    <th colspan="3" class="statichead">Probe mode</th>
                </tr>
            </thead>
            <tbody>
                <tr class="staticeven">
                    <td>Last uplink command</td>
                    <td><span class="livedata" sensorname="liveview_uplink_timestamp"></span></td>
                    <td><span class="livedata" sensorname="liveview_uplink_command"></span></td>
                </tr>
                <tr class="staticodd">
                    <td>Probe system mode</td>
                    <td align="right"><span class="livedata" sensorname="liveview_statechange_timestamp"></span></td>
                    <td align="right"><span class="livedata" sensorname="liveview_statechange_text"></span></td>
                </tr>
            </tbody>
        </table>
    </p>

