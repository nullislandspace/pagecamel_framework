<script>    
    function websocketmaskOnload() {
        $('.livedata').css('font-family', 'SourceCodePro');
    }

    function handleMessage(msg) {                
        if(msg.type === "probedata") {
            var sensorselector = 'span[sensorname="liveview_' + msg.sensor + '"]';
            $(sensorselector).each(function() {
                $(this).text(msg.measurement);

                var highlight_color = "#fbec88";
                var original_color = $(this).css("background-color");
                $(this)
                        .animate({
                                'background-color': highlight_color,
                                'color': '#000000'
                        }, 'slow', 'swing')
                        .delay(1000)
                        .animate({
                                'background-color': original_color
                        }, 'slow', 'swing');

            });
            //animateCell("#liveview_" + msg.sensor);
            return;
        }
        
    }

    function animateCell(cellid) {
        var highlight_color = "#fbec88";
        var original_color = $(cellid).css("background-color");
        $(cellid)
                .animate({
                        'background-color': highlight_color,
                        'color': '#000000'
                }, 'slow', 'swing')
                .delay(1000)
                .animate({
                        'background-color': original_color
                }, 'slow', 'swing');
        return;
    }

</script>
