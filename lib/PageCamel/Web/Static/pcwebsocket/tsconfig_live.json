{
  "include": [
    "src/**/*.ts",
    "*.ts"
  ],
  "exclude": [
    "*.d.ts"
  ],
  "compilerOptions": {
    "allowJs": true,
    "outDir": "out",
    "target": "ES6",
    "module": "ES6",
    "strict": true,
    "removeComments": true,
    "strictNullChecks": true,
    "sourceMap": false,
    "noImplicitAny": true
  }
}
