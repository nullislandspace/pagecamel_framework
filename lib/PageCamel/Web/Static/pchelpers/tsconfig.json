{
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "*.d.ts"
  ],
  "compilerOptions": {
    "allowJs": true,
    "outDir": "out",
    "target": "ES2016",
    "module": "ES6",
    "moduleResolution": "node",
    "strict": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "strictNullChecks": true,
    "sourceMap": false,
    "noImplicitAny": true,
    "declaration": false,
    "declarationMap": false,
  }
}
