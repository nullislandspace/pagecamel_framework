{
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "*.d.ts"
  ],
  "compilerOptions": {
    "allowJs": true,
    "outDir": "out",
    "module": "nodenext",
    "strict": true,
    "removeComments": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "declaration": true,
  }
}
